@page "/gemini-viewer"
@using System.Text.Json
@using System.IO
@using System.Text.RegularExpressions
@rendermode InteractiveServer
<div class="chat-container">

    <div class="gemini-card upload-card">
        <h4>Import History</h4>
        <p class="text-muted">Select your Gemini export JSON file to view it.</p>
        
        <InputFile OnChange="@LoadFiles" accept=".json" class="file-input" />
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">
                ⚠️ @errorMessage
            </div>
        }
    </div>

    @if (entries == null && string.IsNullOrEmpty(errorMessage))
    {
        <div class="empty-state">
            <p>No data loaded. Please upload a JSON file.</p>
        </div>
    }
    else if (entries != null)
    {
        @foreach (var entry in entries)
        {
            <div class="gemini-card">
                <div class="header">
                    <span class="icon">✨</span>
                    <span class="date">@entry.Time.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                </div>
                <p><b>@entry.Title</b></p>
                <div class="gemini-response">
                    @if (entry.SafeHtmlItems != null)
                    {
                        foreach (var htmlItem in entry.SafeHtmlItems)
                        {
                            @((MarkupString)htmlItem.Html)
                        }
                    }
                    else
                    {
                        <p><em>No HTML content found for this entry.</em></p>
                    }
                </div>
                
                @if (entry.Products != null && entry.Products.Any())
                {
                    <div class="footer-tags">
                        Source: @string.Join(", ", entry.Products)
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<GeminiJsonReader>? entries;
    private string? errorMessage;

    // Limit max file size to 10 MB just in case the history is long
    private const long MaxFileSize = 1024 * 1024 * 10; 

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        entries = null;

        IBrowserFile file = e.File;

        try
        {
            // Open the stream from the uploaded file
            using Stream stream = file.OpenReadStream(MaxFileSize);
            using StreamReader reader = new StreamReader(stream);
            
            // Read file to string
            string jsonContent = await reader.ReadToEndAsync();

            // Deserialize with case-insensitive options just to be safe
            JsonSerializerOptions options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

            entries = JsonSerializer.Deserialize<List<GeminiJsonReader>>(jsonContent, options);

            if (entries != null)
            {
                Regex imgRegex = new Regex("<img[^>]*>", RegexOptions.IgnoreCase | RegexOptions.Compiled);
                foreach (GeminiJsonReader entry in entries.Where(entry => entry.SafeHtmlItems != null))
                {
                    foreach (SafeHtmlItem htmlItem in entry.SafeHtmlItems!)
                    {
                        if (!string.IsNullOrEmpty(htmlItem.Html))
                        {
                            htmlItem.Html = imgRegex.Replace(htmlItem.Html, string.Empty);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error reading file: {ex.Message}";
            // In a real app, you might want to log 'ex' to a logging service
        }
    }
}