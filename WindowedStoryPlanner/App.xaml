<Application x:Class="WindowedStoryPlanner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WindowedStoryPlanner"
             xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             xmlns:behaviors="clr-namespace:WindowedStoryPlanner.Views.Behaviors"
             ShutdownMode="OnMainWindowClose">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <v:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <v:CanMoveToChapterConverter x:Key="TypeCheckConverter"/>
            <v:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <v:IsFloatingWindowConverter x:Key="IsFloatingWindowConverter"/>

            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="behaviors:ScrollPassthroughBehavior.Enabled" Value="True"/>
            </Style>

            <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                <Setter Property="behaviors:ScrollPassthroughBehavior.Enabled" Value="True"/>
            </Style>

        </ResourceDictionary>
        
    </Application.Resources>
</Application>
