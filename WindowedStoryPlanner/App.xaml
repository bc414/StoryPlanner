<Application x:Class="WindowedStoryPlanner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WindowedStoryPlanner"
             xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <v:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <v:CanMoveToChapterConverter x:Key="TypeCheckConverter"/>
            <v:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <v:IsFloatingWindowConverter x:Key="IsFloatingWindowConverter"/>
            <v:IsEntityViewModelConverter x:Key="IsEntityViewModelConverter"/>
            <DataTemplate x:Key="ThemeBadgeTemplate" DataType="{x:Type vm:ThemeViewModel}">
                <Border Background="{Binding BadgeBackground}" 
        CornerRadius="3" 
        Margin="3,0,0,0" 
        Padding="4,1"
        SnapsToDevicePixels="True"
        ToolTip="{Binding Name}">
                    <TextBlock Text="{Binding BadgeText}" 
               Foreground="{Binding BadgeForeground}" 
               FontSize="9" 
               FontWeight="Bold" 
               FontFamily="Consolas, monospace"
               VerticalAlignment="Center"/>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="CodexBadgeTemplate" DataType="{x:Type vm:CodexEntryViewModel}">
                <Border BorderBrush="{Binding BadgeBrush}" 
        BorderThickness="1.5"
        Background="Transparent"
        CornerRadius="8" 
        Margin="0,0,4,0" 
        Padding="6,0"
        Height="18"
        SnapsToDevicePixels="True"
        ToolTip="{Binding Title}">
                    <TextBlock Text="{Binding BadgeText}" 
               Foreground="{Binding BadgeBrush}" 
               FontSize="9" 
               FontWeight="Bold"
               VerticalAlignment="Center"/>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="ThreadBadgeTemplate" DataType="{x:Type vm:StoryThreadViewModel}">
                <TextBlock Text="{Binding Icon}" 
           Foreground="{Binding BadgeBrush}"
           ToolTip="{Binding Name}" 
           FontSize="14" 
           Margin="0,0,4,0" 
           VerticalAlignment="Center"
           Cursor="Help"/>
            </DataTemplate>
        </ResourceDictionary>
        
    </Application.Resources>
</Application>
