<Window x:Class="WindowedStoryPlanner.Views.CategorizerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Note Categorizer" Height="800" Width="1200"
        xmlns:dd="urn:gong-wpf-dragdrop"
        >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Cards}" dd:DragDrop.IsDragSource="True">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding BackgroundHex}" 
                                CornerRadius="4" Margin="5" Padding="5" Width="400"
                                BorderThickness="1" BorderBrush="#B0BEC5">

                            <TextBox Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinLines="2" MaxLines="8"
                                     Foreground="#333333" Background="Transparent" 
                                     BorderThickness="0" FontSize="14">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter Property="Opacity" Value="1.0" />
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="False">
                                                <Setter Property="Opacity" Value="0.8" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#FFAA00" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="Margin" Value="4" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Add Note" 
                    Command="{Binding AddCardCommand}" 
                    Height="40" Margin="0,15,0,0" 
                    FontSize="16" FontWeight="Bold" />
                                <Button Content="Paste Buckets from Clipboard" 
                    Command="{Binding PasteBucketsCommand}" 
                    Height="40" Margin="10,15,0,0" 
                    FontSize="16" FontWeight="Bold" />
            <Button Content="Paste Notes from Clipboard" 
                    Command="{Binding PasteNotesCommand}" 
                    Height="40" Margin="10,15,0,0" 
                    FontSize="16" FontWeight="Bold" />
            <Button Content="Copy Edited Notes to Clipboard" 
                    Command="{Binding CopyNotesCommand}" 
                    Height="40" Margin="10,15,0,0" 
                    FontSize="16" FontWeight="Bold" />
            <Button Content="Copy All Notes to Clipboard" 
                Command="{Binding CopyAllNotesCommand}" 
                Height="40" Margin="10,15,0,0" 
                FontSize="16" FontWeight="Bold" />
        </StackPanel>
        
    </Grid>
</Window>