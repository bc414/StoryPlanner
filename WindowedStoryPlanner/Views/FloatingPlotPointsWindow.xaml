<Window x:Class="WindowedStoryPlanner.Views.FloatingPlotPointsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        Title="Floating Plot Points" Height="500" Width="400"
        WindowStartupLocation="CenterOwner">
    
    <DockPanel>
        <!-- Add Button -->
        <Border DockPanel.Dock="Bottom" Padding="10" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,1,0,0">
            <Button Content="+ New Floating Plot Point" 
                    Command="{Binding AddPlotPointCommand}"
                    Padding="10,5"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"/>
        </Border>

        <!-- The Collection Viewer (reuses default styles/logic) -->
        <!-- DataContext is set by the Window creation logic -->
        <local:PlotPointCollectionViewer />
    </DockPanel>
</Window>