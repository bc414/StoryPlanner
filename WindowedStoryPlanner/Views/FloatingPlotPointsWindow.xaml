<Window x:Class="WindowedStoryPlanner.Views.FloatingPlotPointsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        Title="Floating Plot Points" Height="500" Width="400"
        WindowStartupLocation="CenterOwner">
    
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Padding="10" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,1,0,0">
            <Button Content="+ New Idea" 
                    Command="{Binding AddFloatingPlotPointCommand}"
                    Padding="10,5"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"/>
        </Border>

        <local:PlotPointCollectionViewer 
            DataContext="{Binding PlotPointCollectionViewModel}" 
            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" 
            IsDragReorderEnabled="False"
            ShowReorderButtons="False"/>
            
    </DockPanel>
</Window>