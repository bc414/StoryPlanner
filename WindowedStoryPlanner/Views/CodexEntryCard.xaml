<UserControl x:Class="WindowedStoryPlanner.Views.CodexEntryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             mc:Ignorable="d" d:DataContext="{x:Static local:Sample.CodexEntryViewModel}">
    <Grid>
        <Button Width="160" Height="90" Margin="5,5,5,5"
    Command="{Binding OpenWindowCommand}"
    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,10" FontSize="16">
            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" TextAlignment="Center" />
        </Button>
    </Grid>
</UserControl>
