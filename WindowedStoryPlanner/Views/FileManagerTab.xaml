<UserControl x:Class="WindowedStoryPlanner.Views.FileManagerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text="Story Planner" FontSize="32" FontWeight="Bold" Foreground="#444" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Command="{Binding CreateNewProjectCommand}" 
                        Padding="20,15" Margin="0,10" Background="White" BorderBrush="#CCC">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✨" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Create New Project" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Start from scratch with a new database" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding OpenProjectCommand}" 
                        Padding="20,15" Margin="0,10" Background="White" BorderBrush="#CCC">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Open Existing Project" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Load a .db file from your computer" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            <Button Command="{Binding JsonToMarkdownCommand}" 
                Padding="20,15" Margin="0,10" Background="White" BorderBrush="#CCC">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📂" FontSize="20" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="Convert Gemini JSON to Markdown" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Load a .json file and save as .md" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <Button Command="{Binding SaveChangesCommand}" 
                        Padding="20,15" Margin="0,10" Background="White" BorderBrush="#CCC">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Save Project" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Save to the .db file" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding StoreGeminiPromptsCommand}" 
                        Padding="20,15" Margin="0,10" Background="White" BorderBrush="#CCC">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Store Gemini Prompts" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Load Gemini Prompts from a json and save the contents to the .db file" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding BackupToJSONCommand}" 
                        Padding="20,15" Margin="0,10" Background="#F0F8FF" BorderBrush="#ADD8E6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📤" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Backup to JSON" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Export full readable backup" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding RestoreFromJSONCommand}" 
                        Padding="20,15" Margin="0,10" Background="#FFF0F5" BorderBrush="#FFB6C1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Restore from JSON" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Overwrite DB from backup file" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CopyAiContextCommand}" 
                        Padding="20,15" Margin="0,10" Background="#F5F5DC" BorderBrush="#CCC">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖" FontSize="20" Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Copy AI Context" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Copy optimized JSON to clipboard" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </WrapPanel>
    </Grid>
</UserControl>
