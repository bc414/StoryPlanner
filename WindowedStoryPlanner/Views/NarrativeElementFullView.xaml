<UserControl x:Class="WindowedStoryPlanner.Views.NarrativeElementFullView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance Type=vm:NarrativeElementViewModel}"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop">
    <UserControl.Resources>
        <local:NarrativeElementWidgetSelector x:Key="WidgetSelector">
            <local:NarrativeElementWidgetSelector.SubjectTemplate>
                <DataTemplate><local:SubjectWidget/></DataTemplate>
            </local:NarrativeElementWidgetSelector.SubjectTemplate>
            <local:NarrativeElementWidgetSelector.PlotPointTemplate>
                <DataTemplate><local:PlotPointWidget/></DataTemplate>
            </local:NarrativeElementWidgetSelector.PlotPointTemplate>
            <local:NarrativeElementWidgetSelector.LinkTemplate>
                <DataTemplate><local:LinkWidget/></DataTemplate>
            </local:NarrativeElementWidgetSelector.LinkTemplate>
            <local:NarrativeElementWidgetSelector.ChapterTemplate>
                <DataTemplate><local:ChapterWidget/></DataTemplate>
            </local:NarrativeElementWidgetSelector.ChapterTemplate>
        </local:NarrativeElementWidgetSelector>

        <!-- Shared item template for both populated and empty track ItemsControls -->
        <DataTemplate x:Key="NoteTrackItemTemplate">
            <local:NoteTrackView Margin="0,0,8,0">
                <local:NoteTrackView.Style>
                    <Style TargetType="local:NoteTrackView">
                        <Setter Property="Width" Value="360"/>
                        <Style.Triggers>
                            <!-- Archive mode + first track: fill the viewport width -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AppSettings.IsArchiveMode}" Value="True"/>
                                    <Condition Binding="{Binding IsFirstTrack}"             Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Width"
                                        Value="{Binding ViewportWidth,
                                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:NoteTrackView.Style>
            </local:NoteTrackView>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <!-- Top widget area -->
        <ContentControl DockPanel.Dock="Top"
                        MinHeight="80"
                        Margin="8,0,8,0"
                        Content="{Binding}"
                        ContentTemplateSelector="{StaticResource WidgetSelector}"
                        dd:DragDrop.IsDropTarget="True"
                        dd:DragDrop.DropHandler="{Binding}"/>

        <!-- Note tracks -->
        <ScrollViewer x:Name="TrackScrollViewer"
                      DockPanel.Dock="Bottom"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal"
                        Margin="8,4,4,8">

                <!-- ── Populated tracks: horizontal row (left) ── -->
                <ItemsControl ItemsSource="{Binding PopulatedNoteTracks}"
                              VirtualizingPanel.IsVirtualizing="False"
                              ItemTemplate="{StaticResource NoteTrackItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- ── Empty tracks: vertical wrap (right) ── -->
                <!-- WrapPanel fills downward then starts a new column, matching the
                     height of the ScrollViewer so columns align with populated tracks. -->
                <ItemsControl ItemsSource="{Binding EmptyNoteTracks}"
                              VirtualizingPanel.IsVirtualizing="False"
                              ItemTemplate="{StaticResource NoteTrackItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical"
                                       Height="{Binding ActualHeight,
                                               RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
