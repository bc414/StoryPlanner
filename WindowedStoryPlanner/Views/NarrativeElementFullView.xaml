<UserControl x:Class="WindowedStoryPlanner.Views.NarrativeElementFullView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance Type=vm:NarrativeElementViewModel}"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             dd:DragDrop.IsDropTarget="True"
             dd:DragDrop.DropHandler="{Binding}">
    <UserControl.Resources>
        <CollectionViewSource x:Key="SortedNoteTracks" Source="{Binding NoteTracks}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="DisplayOrder" Direction="Ascending"
                                 xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <!-- Outer ScrollViewer owns all vertical scrolling for the window -->
    <ScrollViewer x:Name="RootScroller"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Main content area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT / MAIN COLUMN ══════════════════════════════════════ -->
            <DockPanel Grid.Column="0" LastChildFill="True">

                <!-- Top placeholder content control -->
                <ContentControl DockPanel.Dock="Top"
                            x:Name="TopContentPlaceholder"
                            MinHeight="80"
                            Margin="8,8,8,4"
                            Content="{Binding}"
                            Visibility="Collapsed">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
                            <local:SubjectWidget/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:PlotPointViewModel}">
                            <local:PlotPointWidget/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>

                <!-- Note tracks — sorted, no internal vertical scroll -->
                <ItemsControl
                          ItemsSource="{Binding Source={StaticResource SortedNoteTracks}}"
                          Margin="8,4,4,8"
                          VirtualizingPanel.IsVirtualizing="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:NoteTrackView Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            
        </Grid>
    </ScrollViewer>
</UserControl>
