<UserControl x:Class="WindowedStoryPlanner.Views.ThemeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             d:DataContext="{x:Static local:Sample.ThemeViewModel}"
             mc:Ignorable="d"
             
             dd:DragDrop.IsDropTarget="True"
             dd:DragDrop.DropHandler="{Binding}"
             Style="{StaticResource EntityCardStyle}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:ThemeBadgeCollection Grid.Column="0" Margin="0,0,5,0" VerticalAlignment="Center"/>

        <TextBlock Text="{Binding Name}" 
                   TextWrapping="Wrap" 
                   TextAlignment="Left" 
                   Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="16"/>
    </Grid>
</UserControl>