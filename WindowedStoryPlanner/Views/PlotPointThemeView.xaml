<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
             mc:Ignorable="d"
             d:DataContext="{x:Static local:Sample.PlotPointTheme}">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="ThemeProminenceEnum" MethodName="GetValues" ObjectType="{x:Type m:ThemeProminence}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:ThemeProminence"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="PROMINENCE" Style="{StaticResource LabelStyle}"/>
        <ComboBox ItemsSource="{Binding Source={StaticResource ThemeProminenceEnum}}"
          SelectedItem="{Binding Prominence}"/>
        <TextBlock Text="COMMENTARY" Style="{StaticResource LabelStyle}"/>
        <TextBox Text="{Binding Commentary, UpdateSourceTrigger=PropertyChanged}"
         Style="{StaticResource AutoGrowingTextBox}"
         MinHeight="60"/>

    </StackPanel>
</UserControl>
