<UserControl x:Class="WindowedStoryPlanner.Views.NoteCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
             d:DataContext="{x:Static v:Sample.NoteViewModel}"
             mc:Ignorable="d">
    
    <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"></TextBlock>
        <Button Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=v:NoteViewer}}" 
                CommandParameter="{Binding}" Content="Delete"/>
    </StackPanel>
</UserControl>
