<Window x:Class="WindowedStoryPlanner.Views.PlotPointCodexEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d"
        d:DataContext="{x:Static local:Sample.PlotPointCodexEntry}"
        SizeToContent="Height" Width="250"
        Title="{Binding CodexEntry.Title, StringFormat='Codex: {0}'}">

    <Window.Resources>
        <ObjectDataProvider x:Key="CodexUsageTypeEnum" MethodName="GetValues" ObjectType="{x:Type m:CodexUsageType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:CodexUsageType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <StackPanel>
        <TextBlock Text="USAGE TYPE" Style="{StaticResource LabelStyle}"/>
        <ComboBox ItemsSource="{Binding Source={StaticResource CodexUsageTypeEnum}}"
                  SelectedItem="{Binding UsageType}"/>

        <TextBlock Text="COMMENTARY" Style="{StaticResource LabelStyle}"/>
        <TextBox Text="{Binding Commentary, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AutoGrowingTextBox}"
                 MinHeight="60"/>

        <UniformGrid Columns="2" Margin="0,15,0,0">
            <Button Content="Unlink" 
                    Command="{Binding UnlinkCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                    HorizontalAlignment="Center" Width="100"/>
            <Button Content="Close" 
                    HorizontalAlignment="Center" Width="100" 
                    Click="CloseButton_Click"/>
        </UniformGrid>

    </StackPanel>
</Window>