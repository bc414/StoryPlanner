<Window x:Class="WindowedStoryPlanner.Views.PlotPointWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d" d:DataContext="{x:Static local:Sample.PlotPointViewModel}" Width="800">
    <Window.Resources>
        <ObjectDataProvider x:Key="CoreDriverEnum" MethodName="GetValues" ObjectType="{x:Type m:CoreDriver}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:CoreDriver"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="TensionPhaseEnum" MethodName="GetValues" ObjectType="{x:Type m:TensionPhase}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:TensionPhase"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="ConflictTypeEnum" MethodName="GetValues" ObjectType="{x:Type m:ConflictType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:ConflictType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="PresentationEnum" MethodName="GetValues" ObjectType="{x:Type m:Presentation}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:Presentation"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="DraftStatusEnum" MethodName="GetValues" ObjectType="{x:Type m:DraftStatus}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:DraftStatus"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#555555"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="TextBox" x:Key="AutoGrowingTextBox">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel>

            <GroupBox Header="General Information">
                <StackPanel>
                    <TextBlock Text="SCENE TITLE" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="16" FontWeight="Bold" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="CHAPTER CONTEXT" Style="{StaticResource LabelStyle}"/>
                    <local:CardCollectionViewer 
                        ItemsSource="{Binding Chapters}" 
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ViewPayloadCommand="{Binding ViewChapterCommand}"/>
                </StackPanel>
            </GroupBox>


            <GroupBox Header="Narrative Analysis">
                <UniformGrid Columns="2" Rows="2">

                    <StackPanel Margin="0,0,10,10">
                        <TextBlock Text="CORE DRIVER" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource CoreDriverEnum}}"
                                  SelectedItem="{Binding CoreDriver}" Padding="5"/>
                    </StackPanel>

                    <StackPanel Margin="10,0,0,10">
                        <TextBlock Text="TENSION PHASE" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource TensionPhaseEnum}}"
                                  SelectedItem="{Binding TensionPhase}" Padding="5"/>
                    </StackPanel>

                    <StackPanel Margin="0,10,10,0">
                        <TextBlock Text="CONFLICT TYPE" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource ConflictTypeEnum}}"
                                  SelectedItem="{Binding ConflictType}" Padding="5"/>
                    </StackPanel>

                    <StackPanel Margin="10,10,0,0">
                        <TextBlock Text="PRESENTATION" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource PresentationEnum}}"
                                  SelectedItem="{Binding Presentation}" Padding="5"/>
                    </StackPanel>

                </UniformGrid>
            </GroupBox>


            <GroupBox Header="Connections">
                <StackPanel>

                    <TextBlock Text="STORY THREADS" Style="{StaticResource LabelStyle}"/>
                    <local:CardCollectionViewer ItemsSource="{Binding StoryThreads}"
                                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                UnlinkItemCommand="{Binding UnlinkThreadCommand}"
                                                ViewPayloadCommand="{Binding ViewThreadPayloadCommand}"
                                                Margin="0,0,0,10"/>

                    <TextBlock Text="CHARACTERS" Style="{StaticResource LabelStyle}"/>
                    <local:CardCollectionViewer ItemsSource="{Binding Characters}" 
                                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                UnlinkItemCommand="{Binding UnlinkCharacterCommand}"
                                                ViewPayloadCommand="{Binding ViewCharacterPayloadCommand}"
                                                Margin="0,0,0,10"/>

                    <TextBlock Text="THEMES" Style="{StaticResource LabelStyle}"/>
                    <local:CardCollectionViewer ItemsSource="{Binding Themes}" 
                                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                UnlinkItemCommand="{Binding UnlinkThemeCommand}"
                                                ViewPayloadCommand="{Binding ViewThemePayloadCommand}"
                                                Margin="0,0,0,10"/>

                    <TextBlock Text="CODEX / LORE" Style="{StaticResource LabelStyle}"/>
                    <local:CardCollectionViewer ItemsSource="{Binding CodexEntries}" 
                                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                UnlinkItemCommand="{Binding UnlinkCodexCommand}"
                                                ViewPayloadCommand="{Binding ViewCodexPayloadCommand}"
                                                Margin="0,0,0,10"/>

                    <TextBlock Text="LOCATION" Style="{StaticResource LabelStyle}"/>
                    <local:CardCollectionViewer ItemsSource="{Binding Locations}" 
                                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                UnlinkItemCommand="{Binding UnlinkLocationCommand}"
                                                ViewPayloadCommand="{Binding ViewLocationPayloadCommand}"/>
                </StackPanel>
            </GroupBox>


            <GroupBox Header="Drafting">
                <StackPanel>

                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBlock Text="CURRENT STATUS:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <ComboBox Width="150" 
                                  ItemsSource="{Binding Source={StaticResource DraftStatusEnum}}"
                                  SelectedItem="{Binding Status}"/>
                    </DockPanel>

                    <Separator Margin="0,0,0,15"/>

                    <TextBlock Text="STAKES (Why does this scene matter?)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Stakes, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource AutoGrowingTextBox}"/>

                    <TextBlock Text="SYNOPSIS (What happens?)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Synopsis, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource AutoGrowingTextBox}"
                             MinHeight="60"/>

                    <TextBlock Text="OUTCOME (What changed?)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Outcome, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource AutoGrowingTextBox}"/>

                    <TextBlock Text="VERBATIM TEXT (Draft)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding VerbatimText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource AutoGrowingTextBox}"
                             MinHeight="100"
                             FontFamily="Consolas, Courier New, Monospace"/>

                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
