<UserControl x:Class="WindowedStoryPlanner.Views.StoryThreadCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             mc:Ignorable="d"
             d:DataContext="{x:Static local:Sample.StoryThreadViewModel}">
    <Grid>
        <Button Width="160" Height="90" Margin="5,5,5,5"
        Command="{Binding OpenWindowCommand}"
        HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,10" FontSize="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Icon}" 
                   FontSize="20" 
                   Grid.Column="0" 
                   Margin="0,0,5,0"
                   VerticalAlignment="Center"/>

                <TextBlock Text="{Binding Name}" 
                   TextWrapping="Wrap" 
                   TextAlignment="Center" 
                   Grid.Column="1"
                   VerticalAlignment="Center" />
            </Grid>
        </Button>
    </Grid>
</UserControl>
