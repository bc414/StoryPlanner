<UserControl x:Class="WindowedStoryPlanner.Views.LinkWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:PlotPointSubjectLinkViewModel}">
    <Border BorderBrush="#CCCCCC"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12,8"
            Margin="8"
            Background="#F8F8F8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="LINK"
                           Style="{StaticResource LabelStyle}"/>
                <WrapPanel>
                    <TextBlock Text="{Binding SubjectName}"
                               FontSize="16"
                               FontWeight="Bold"/>
                    <TextBlock Text=" · "
                               FontSize="16"
                               Foreground="#AAAAAA"/>
                    <TextBlock Text="{Binding SubjectTypeName}"
                               FontSize="16"
                               Foreground="#666666"/>
                    <TextBlock Text="  ⟷  "
                               FontSize="16"
                               Foreground="#AAAAAA"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PlotPointDisplayText}"
                               FontSize="16"
                               FontWeight="Bold"/>
                </WrapPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Command="{Binding DeleteSelfCommand}"
                    Content="✕"
                    ToolTip="Delete link (only available when there are no notes)"
                    VerticalAlignment="Top"
                    Margin="8,0,0,0"
                    Padding="6,2"
                    FontSize="12"
                    Foreground="#CC3333"
                    Background="Transparent"
                    BorderBrush="#CC3333"
                    BorderThickness="1"
                    Cursor="Hand"/>
        </Grid>
    </Border>
</UserControl>
