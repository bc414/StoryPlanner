<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointThreadView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d"
        d:DataContext="{x:Static local:Sample.PlotPointThread}">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="GoalTrajectoryEnum" MethodName="GetValues" ObjectType="{x:Type m:GoalTrajectory}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:GoalTrajectory"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="TRAJECTORY" Style="{StaticResource LabelStyle}"/>
        <ComboBox ItemsSource="{Binding Source={StaticResource GoalTrajectoryEnum}}"
                  SelectedItem="{Binding ThreadTrajectory}"/>

        <CheckBox Content="Primary Thread?" 
                  IsChecked="{Binding IsPrimary}"
                  Margin="0,10,0,0"
                  HorizontalAlignment="Left"/>

        <TextBlock Text="IMPACT" Style="{StaticResource LabelStyle}"/>
        <TextBox Text="{Binding ImpactDescription, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AutoGrowingTextBox}"
                 MinHeight="60"/>

    </StackPanel>
</UserControl>