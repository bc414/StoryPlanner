<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner"
             xmlns:models="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
             d:DataContext="{d:DesignInstance Type=models:PlotPoint, IsDesignTimeCreatable=True}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Title}"></TextBlock>
    </StackPanel>
</UserControl>
