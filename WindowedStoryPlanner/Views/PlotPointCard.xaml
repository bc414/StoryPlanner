<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner"
             xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
             d:DataContext="{x:Static v:Sample.PlotPointViewModel}"
             mc:Ignorable="d">
    <StackPanel Orientation="Horizontal">
        <Button Width="160" Height="90" Margin="5,5,5,5"
    Command="{Binding OpenWindowCommand}"
    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,10" FontSize="16">
            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" TextAlignment="Center" />
        </Button>
    </StackPanel>
</UserControl>
