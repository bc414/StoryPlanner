<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner"
             xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             d:DataContext="{x:Static v:Sample.PlotPointViewModel}"
             mc:Ignorable="d"
             Style="{StaticResource CardBaseStyle}"
             Margin="2,5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Ellipse Grid.Column="0" 
                 Width="8" Height="8" 
                 Fill="Black" 
                 VerticalAlignment="Top" 
                 Margin="2,5,8,0"/>

        <TextBlock Grid.Column="1"
                   Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                   TextWrapping="Wrap"
                   VerticalAlignment="Stretch"
                   ContextMenu="{x:Null}"/>
    </Grid>
</UserControl>
