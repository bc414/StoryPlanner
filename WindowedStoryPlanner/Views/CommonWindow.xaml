<Window x:Class="WindowedStoryPlanner.Views.CommonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        xmlns:behaviors="clr-namespace:WindowedStoryPlanner.Views.Behaviors"
        mc:Ignorable="d"
        Title="Story Planner"
        Height="900" Width="1600"
        MinWidth="600" MinHeight="400"
        WindowState="Maximized" d:DataContext="{d:DesignInstance Type=local:CommonWindow}">

    <Window.Resources>
        <!-- Typed DataTemplates: ContentControl resolves these automatically by Content type -->
        <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
            <local:NarrativeElementFullView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlotPointViewModel}">
            <local:NarrativeElementFullView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlotPointSubjectLinkViewModel}">
            <local:NarrativeElementFullView/>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Mode button style -->
        <Style x:Key="ModeButtonStyle" TargetType="Button">
            <Setter Property="Padding"     Value="8,4"/>
            <Setter Property="Margin"      Value="2,4"/>
            <Setter Property="MinWidth"    Value="90"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C8C8C8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            </Trigger>
                            <!-- Active + disabled: keep white text over the blue background -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsEnabled" Value="False"/>
                                    <Condition Property="Tag"       Value="Active"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Active/selected mode -->
                <Trigger Property="Tag" Value="Active">
                    <Setter Property="Background"  Value="#00FF00"/>
                    <Setter Property="Foreground"  Value="White"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOP MODE BAR ═════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT ZONE: Expansion button + subject picker button -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ExpansionModeButton"
                        Content="Expansion"
                        Style="{StaticResource ModeButtonStyle}"
                        ToolTip="Expansion mode — subject only, no links (middle-click to open in new window)"
                        Click="ExpansionMode_Click"
                        PreviewMouseDown="ExpansionModeButton_PreviewMouseDown"/>

                <!-- Subject picker toggle button -->
                <Button x:Name="SubjectPickerButton"
                        Style="{StaticResource PickerButtonStyle}"
                        ToolTip="Pick subject"
                        Click="SubjectPickerButton_Click">
                    <TextBlock Text="⌖" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <!-- Subject picker flyout -->
                <Popup x:Name="SubjectPickerPopup"
                       PlacementTarget="{Binding ElementName=SubjectPickerButton}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <local:SubjectPickerControl x:Name="SubjectPicker"/>
                </Popup>
            </StackPanel>

            <!-- CENTER ZONE: Linking + create-link picker + Archive toggle -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="LinkingModeButton"
                        Content="Linking"
                        Style="{StaticResource ModeButtonStyle}"
                        ToolTip="Linking mode — subject on left (read-only), selected link tracks on right"
                        Click="LinkingMode_Click"/>

                <!-- Create-link picker toggle button -->
                <Button x:Name="CreateLinkButton"
                        Style="{StaticResource PickerButtonStyle}"
                        ToolTip="Create a new link to this subject / plot point"
                        Click="CreateLinkButton_Click">
                    <TextBlock Text="🔗" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <!-- Create-link: plot point picker (Expansion and Linking modes) -->
                <Popup x:Name="CreateLinkPlotPointPickerPopup"
                       PlacementTarget="{Binding ElementName=CreateLinkButton}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <local:PlotPointPickerControl x:Name="CreateLinkPlotPointPicker"/>
                </Popup>

                <!-- Create-link: subject picker (Gardener mode) -->
                <Popup x:Name="CreateLinkSubjectPickerPopup"
                       PlacementTarget="{Binding ElementName=CreateLinkButton}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <local:SubjectPickerControl x:Name="CreateLinkSubjectPicker"/>
                </Popup>

                <CheckBox Content="Archive"
                          VerticalAlignment="Center"
                          Margin="12,0,4,0"
                          ToolTip="Archive mode — enables promoting notes to Confirmed and expands note tracks to full width"
                          IsChecked="{Binding AppSettings.IsArchiveMode, Mode=TwoWay}"/>
            </StackPanel>

            <!-- RIGHT ZONE: plot point picker button + Gardener button -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Right">

                <!-- Plot point picker toggle button -->
                <Button x:Name="PlotPointPickerButton"
                        Style="{StaticResource PickerButtonStyle}"
                        ToolTip="Pick plot point"
                        Click="PlotPointPickerButton_Click">
                    <TextBlock Text="⌖" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <!-- Plot point picker flyout -->
                <Popup x:Name="PlotPointPickerPopup"
                       PlacementTarget="{Binding ElementName=PlotPointPickerButton}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <local:PlotPointPickerControl x:Name="PlotPointPicker"/>
                </Popup>

                <Button x:Name="GardenerModeButton"
                        Content="Gardener"
                        Style="{StaticResource ModeButtonStyle}"
                        ToolTip="Gardener mode — plot point on right, selected link tracks on left (middle-click to open in new window)"
                        Click="GardenerMode_Click"
                        PreviewMouseDown="GardenerModeButton_PreviewMouseDown"/>
            </StackPanel>
        </Grid>

        <!-- ══ THREE-COLUMN CONTENT AREA ════════════════════════════════════ -->
        <Grid x:Name="ContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ─────────────────────────────────────────────── -->
            <ContentControl x:Name="LeftPanel"
                            Grid.Column="0"
                            Visibility="Collapsed"/>

            <!-- ── MIDDLE LINK CARD BAR ───────────────────────────────────── -->
            <Border x:Name="LinkPanelBorder"
                    Grid.Column="1"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top row: clear (X) button aligned to right -->
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="4,6,4,2">
                        <Button x:Name="ClearLinkButton"
                                Content="✕"
                                Width="26"
                                Height="22"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                ToolTip="Clear selected link"
                                Click="ClearSelectedLink_Click"/>
                    </DockPanel>

                    <!-- Link cards list -->
                    <ListBox x:Name="LinkCardsListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             behaviors:ScrollPassthroughBehavior.Enabled="False"
                             ItemsSource="{Binding LinkItems}"
                             SelectedItem="{Binding SelectedLink, Mode=TwoWay}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="2"/>
                                <Setter Property="Margin" Value="0,2,0,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#C8EDCC"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#E8F5E9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PlotPointSubjectLinkViewModel}">
                                <local:LinkCardView/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ── RIGHT PANEL ────────────────────────────────────────────── -->
            <ContentControl x:Name="RightPanel"
                            Grid.Column="2"
                            Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
