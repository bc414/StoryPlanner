<Window x:Class="WindowedStoryPlanner.Views.IdeaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d"
        Title="IdeaWindow" Height="450" Width="800" d:DataContext="{x:Static local:Sample.Idea}">
    <Window.Resources>
        <ObjectDataProvider x:Key="IdeaStateEnum" MethodName="GetValues" ObjectType="{x:Type m:IdeaState}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:IdeaState"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,10,0">
            <TextBlock Text="Status" Style="{StaticResource LabelStyle}"/>
            <ComboBox ItemsSource="{Binding Source={StaticResource IdeaStateEnum}}"
                      SelectedItem="{Binding State}" Width="150"
                      Padding="5" Margin="0,0,0,10"/>
        </StackPanel>
        <TextBox Style="{StaticResource AutoGrowingTextBox}" Text="{Binding Text}"></TextBox>
    </DockPanel>
</Window>
