<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointCharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
             mc:Ignorable="d"
             d:DataContext="{x:Static local:Sample.PlotPointCharacter}">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="CharacterRoleEnum" MethodName="GetValues" ObjectType="{x:Type m:CharacterRole}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:CharacterRole"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="CharacterDevImpactEnum" MethodName="GetValues" ObjectType="{x:Type m:CharacterDevImpact}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:CharacterDevImpact"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="ROLE" Style="{StaticResource LabelStyle}"/>
        <ComboBox ItemsSource="{Binding Source={StaticResource CharacterRoleEnum}}"
                  SelectedItem="{Binding Role}"/>

        <TextBlock Text="DEV IMPACT" Style="{StaticResource LabelStyle}"/>
        <ComboBox ItemsSource="{Binding Source={StaticResource CharacterDevImpactEnum}}"
                  SelectedItem="{Binding DevelopmentImpact}"/>

        <TextBlock Text="DEV NOTE" Style="{StaticResource LabelStyle}"/>
        <TextBox Text="{Binding DevelopmentNote, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AutoGrowingTextBox}"
                 MinHeight="60"/>

    </StackPanel>
</UserControl>