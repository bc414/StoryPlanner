<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             d:DataContext="{d:DesignInstance Type=vm:PlotPointViewModel}">
    <UserControl.Resources>
        <DataTemplate x:Key="PlotPointDragAdorner" DataType="{x:Type vm:PlotPointViewModel}">
            <Border BorderBrush="#4A90D9"
                    BorderThickness="2"
                    CornerRadius="4"
                    Padding="10,5"
                    Background="White"
                    Opacity="0.9">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔗 "
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="8">
            
            <Border dd:DragDrop.IsDragSource="True"
                    dd:DragDrop.DragAdornerTemplate="{StaticResource PlotPointDragAdorner}"
                    BorderBrush="#AAAAAA"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="8,4"
                    Margin="0,4,0,0"
                    Background="#F5F5F5"
                    Cursor="SizeAll"
                    HorizontalAlignment="Left"
                    ToolTip="Drag to chapter to move or subject to link">
                <TextBlock Text="⠿ Drag to chapter to move or subject to link"
                           FontSize="11"
                           Foreground="#666666"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
