<Window x:Class="WindowedStoryPlanner.Views.AuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
        Title="Audit Old Text" Height="600" Width="800" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <v:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <v:RecencyToColorConverter x:Key="RecencyToColorConverter" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Audit Old Text" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="Refresh" Command="{Binding RefreshAuditableItemsCommand}" Style="{StaticResource AddButtonStyle}" Width="100" Height="35"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding AuditableItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10" Background="White" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Type}" FontWeight="Bold" Foreground="#666666" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding LastModified, StringFormat='{}{0:g}', Converter={StaticResource UtcToLocalConverter}}" Foreground="{Binding LastModified, Converter={StaticResource RecencyToColorConverter}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <Button Content="{Binding OwnerName, StringFormat='Navigate to: {0}'}" 
                                            Command="{Binding NavigateToOwnerCommand}"
                                            HorizontalAlignment="Left"
                                            Background="#F0F8FF" BorderBrush="#ADD8E6" Padding="10,5"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1" Content="Mark as Audited" 
                                        Command="{Binding MarkAsAuditedCommand}"
                                        VerticalAlignment="Top"
                                        Background="#E8F5E9" BorderBrush="#4CAF50" Foreground="#2E7D32" Padding="10,5"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>