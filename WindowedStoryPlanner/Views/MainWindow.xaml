<Window x:Class="WindowedStoryPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
            
        Title="Mission Control" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen">

    <TabControl TabStripPlacement="Left">

        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Height" Value="60" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Padding" Value="10" />
            </Style>
        </TabControl.Resources>
        <TabItem Header="File Management">
            <v:FileManagerTab/>
        </TabItem>

        <TabItem Header="Chapters">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding ChapterViewModels}" DeleteItemCommand="{Binding DeleteChapterCommand}"/>
                    <Button Content="Add Chapter" Command="{Binding AddChapterCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Story Threads">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding StoryThreadViewModels}" DeleteItemCommand="{Binding DeleteStoryThreadCommand}"/>
                    <Button Content="Add StoryThread"  Command="{Binding AddStoryThreadCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Characters">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding CharacterViewModels}" DeleteItemCommand="{Binding DeleteCharacterCommand}"/>
                    <Button Content="Add Character"  Command="{Binding AddCharacterCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="CodexEntries">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <ListView ItemsSource="{Binding CodexEntriesGroupedView}"
          BorderThickness="0"
          Background="Transparent"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled" dd:DragDrop.IsDragSource="True" dd:DragDrop.UseDefaultDragAdorner="True">

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.GroupStyle>
                            <GroupStyle>

                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="False" Margin="0,0,0,20">

                                                        <Expander.Header>
                                                            <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,2" 
                                                Padding="5" Margin="10,0,0,0"
                                                HorizontalAlignment="Stretch">
                                                                <TextBlock Text="{Binding Name}" 
                                                       Style="{StaticResource LabelStyle}"/>
                                                            </Border>
                                                        </Expander.Header>

                                                        <ItemsPresenter />

                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>

                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" IsItemsHost="True" Margin="20,10,0,0"/>
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>

                            </GroupStyle>
                        </ListView.GroupStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CodexEntryViewModel}">
                                <v:CodexEntryCard Margin="0,0,10,10"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Delete" 
                                  Command="{Binding DataContext.DeleteCodexEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>

                    </ListView>
                    <Button Content="Add Codex Entry"  
                    Command="{Binding AddCodexEntryCommand}" 
                    Style="{StaticResource AddButtonStyle}"
                    Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Themes">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding ThemeViewModels}" DeleteItemCommand="{Binding DeleteThemeCommand}"/>
                    <Button Content="Add Theme"  Command="{Binding AddThemeCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <TabItem Header="PlotPoints">
            <DockPanel>
                <Button DockPanel.Dock="Top" Content="Open Floating Plot Points" 
                Command="{Binding OpenFloatingPointsCommand}" 
                Width="160" Height="40" Margin="10"/>

                <v:PlotPointCollectionViewer DataContext="{Binding PlotPointsByTextViewModel}" />
            </DockPanel>
        </TabItem>
        <TabItem Header="Gemini Prompts">
            <v:GeminiLibrary />
        </TabItem>
        <TabItem Header="Ideas">
            <ScrollViewer>
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Ideas}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:Idea}">
                                <v:IdeaCard/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Add Idea" Command="{Binding AddIdeaCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Note Length">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding DashboardEntities}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Locations">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding LocationViewModels}" DeleteItemCommand="{Binding DeleteLocationCommand}"/>
                    <Button Content="Add Location"  Command="{Binding AddLocationCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Sources">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox ItemsSource="{Binding SourceMaterials}" 
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:SourceMaterial}">
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="2*"/>   <ColumnDefinition Width="80"/>   <ColumnDefinition Width="100"/>  <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" 
                                            Margin="0,0,10,0" BorderBrush="#999" BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding ColorHex}"/>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Name" FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Abbr." FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding Abbreviation, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Color (Hex)" FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" FontFamily="Consolas" 
                                                 BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <Button Grid.Column="4" Content="🗑" Width="30" Height="30"
                                            Background="Transparent" BorderThickness="0" Foreground="Red"
                                            Command="{Binding DataContext.DeleteSourceMaterialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="1" Content="Add Source Material" Height="40" Margin="0,10,0,0"
                        Command="{Binding AddSourceMaterialCommand}" 
                        Background="#F0F8FF" BorderBrush="#ADD8E6"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>