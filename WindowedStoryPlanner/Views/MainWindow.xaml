<Window x:Class="WindowedStoryPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
            
        Title="Mission Control" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen" d:DataContext="{d:DesignInstance Type=vm:ViewModelLocator}" WindowState="Maximized">
    <Window.Resources>
        <v:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <v:RecencyToColorConverter x:Key="RecencyToColorConverter" />
    </Window.Resources>

    <TabControl TabStripPlacement="Left">

        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Height" Value="60" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Padding" Value="10" />
            </Style>
        </TabControl.Resources>
        <TabItem Header="File Management">
            <v:FileManagerTab DataContext="{Binding FileManager}"/>
        </TabItem>

        <TabItem Header="Chapters">
            <v:ChapterLibrary DataContext="{Binding Chapters}"/>
        </TabItem>
        <TabItem Header="Subjects">
            <v:SubjectLibrary DataContext="{Binding Subjects}"/>
        </TabItem>
        <TabItem Header="Themes">
            <v:ThemeLibrary DataContext="{Binding Themes}"/>
        </TabItem>
        <TabItem Header="Definitions">
            <ScrollViewer>
                <v:DefinitionsEditorControl DataContext="{Binding Definitions}"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Global Search">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBlock Text="Search Entities (Characters, Chapters, Threads, etc.)" 
                               FontSize="14" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="20" Padding="5" Height="40" 
                             VerticalContentAlignment="Center"
                             Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <TabItem Header="Sources">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox ItemsSource="{Binding SourceMaterials}" 
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:SourceMaterial}">
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" 
                                            Margin="0,0,10,0" BorderBrush="#999" BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding ColorHex}"/>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Name" FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Abbr." FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding Abbreviation, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Color (Hex)" FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" FontFamily="Consolas" 
                                                 BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <Button Grid.Column="4" Content="🗑" Width="30" Height="30"
                                            Background="Transparent" BorderThickness="0" Foreground="Red"
                                            Command="{Binding DataContext.DeleteSourceMaterialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="1" Content="Add Source Material" Height="40" Margin="0,10,0,0"
                        Command="{Binding AddSourceMaterialCommand}" 
                        Background="#F0F8FF" BorderBrush="#ADD8E6"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
