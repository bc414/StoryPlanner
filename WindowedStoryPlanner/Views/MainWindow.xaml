<Window x:Class="WindowedStoryPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:m="clr-namespace:StoryPlanner.Core.Models;assembly=StoryPlanner.Core"
        mc:Ignorable="d"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
            
        Title="Mission Control" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen" d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <Window.Resources>
        <v:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <v:RecencyToColorConverter x:Key="RecencyToColorConverter" />
    </Window.Resources>

    <TabControl TabStripPlacement="Left">

        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Height" Value="60" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Padding" Value="10" />
            </Style>
        </TabControl.Resources>
        <TabItem Header="File Management">
            <v:FileManagerTab/>
        </TabItem>

        <TabItem Header="Chapters">
            <ScrollViewer>
                <StackPanel>
                    
                    <Button Content="Add Chapter" Command="{Binding AddChapterCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Subjects">
            <ScrollViewer>
                <StackPanel>
                    
                    <Button Content="Add StoryThread"  Command="{Binding AddStoryThreadCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Definitions">
            <ScrollViewer>
                <v:DefinitionsEditorWindow/>
            </ScrollViewer>
        </TabItem>
        
        
        <TabItem Header="PlotPoints">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
                    <Button Content="Open Floating Plot Points" 
                    Command="{Binding OpenFloatingPointsCommand}" 
                    Width="200" Height="40" Margin="0,0,10,0"/>

                    <Button Content="Open Text Audit" 
Command="{Binding OpenAuditWindowCommand}" 
Width="200" Height="40" Margin="0,0,10,0"/>

                    <Button Content="Open Note Categorizer" 
                    Command="{Binding OpenNoteCategorizerCommand}" 
                    Width="200" Height="40" />

                    
                </StackPanel>

            </DockPanel>
        </TabItem>
        <TabItem Header="Gemini Prompts">
            <v:GeminiLibrary />
        </TabItem>
        <TabItem Header="Ideas">
            <ScrollViewer>
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Ideas}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:Idea}">
                                <v:IdeaCard/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="🎲 Fix Random Analysis Item" 
                    Command="{Binding OpenRandomAnalysisEntityCommand}" 
                    Padding="10,5"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right" />
                    <Button Content="Add Idea" Command="{Binding AddIdeaCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Note Length">
            <ScrollViewer>
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Project Note Analysis" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <Button Content="Refresh Statistics" 
                            Command="{Binding RefreshStatisticsCommand}" 
                            Width="150" Height="35" 
                            Style="{StaticResource AddButtonStyle}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding DataGridStats}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="#E0E0E0"
                          VerticalGridLinesBrush="#E0E0E0"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1"
                          RowBackground="White"
                          AlternatingRowBackground="#F7F9FA"
                          RowHeight="35"
                          FontSize="14">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Metric" Binding="{Binding StatName}" FontWeight="SemiBold" Width="180"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="80" FontWeight="Bold" Foreground="#333333"/>
                                <DataGridTextColumn Header="Characters" Binding="{Binding Characters}" Width="100"/>
                                <DataGridTextColumn Header="Themes" Binding="{Binding Themes}" Width="100"/>
                                <DataGridTextColumn Header="Codex" Binding="{Binding Codex}" Width="100"/>
                                <DataGridTextColumn Header="Chapters" Binding="{Binding Chapters}" Width="100"/>
                                <DataGridTextColumn Header="Threads" Binding="{Binding Threads}" Width="100"/>
                                <DataGridTextColumn Header="Unassigned" Binding="{Binding Unassigned}" Width="100" Foreground="Gray"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                    <TextBlock Text="Cards sorted by combined character count:" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Global Search">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBlock Text="Search Entities (Characters, Chapters, Threads, etc.)" 
                               FontSize="14" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="20" Padding="5" Height="40" 
                             VerticalContentAlignment="Center"
                             Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <TabItem Header="Sources">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox ItemsSource="{Binding SourceMaterials}" 
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:SourceMaterial}">
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" 
                                            Margin="0,0,10,0" BorderBrush="#999" BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding ColorHex}"/>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Name" FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Abbr." FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding Abbreviation, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="Color (Hex)" FontSize="10" Foreground="Gray"/>
                                        <TextBox Text="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" FontFamily="Consolas" 
                                                 BorderThickness="0,0,0,1" Background="Transparent"/>
                                    </StackPanel>

                                    <Button Grid.Column="4" Content="🗑" Width="30" Height="30"
                                            Background="Transparent" BorderThickness="0" Foreground="Red"
                                            Command="{Binding DataContext.DeleteSourceMaterialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="1" Content="Add Source Material" Height="40" Margin="0,10,0,0"
                        Command="{Binding AddSourceMaterialCommand}" 
                        Background="#F0F8FF" BorderBrush="#ADD8E6"/>
            </Grid>
        </TabItem>

        <TabItem Header="Unassigned Notes">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Inbox / Unassigned Notes" FontSize="20" FontWeight="SemiBold" Foreground="#333" Margin="0,0,20,0"/>

                    <Button Content="🗑 Purge All" 
    Command="{Binding DataContext.PurgeUnassignedNotesCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
    Background="#FFF0F0" Foreground="Red" BorderBrush="Red" Padding="10,5"/>
                </StackPanel>

                
            </Grid>
        </TabItem>

    </TabControl>
</Window>
