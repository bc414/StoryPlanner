<Window x:Class="WindowedStoryPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:WindowedStoryPlanner.Views"
        mc:Ignorable="d"
            
        Title="Mission Control" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <TabControl TabStripPlacement="Left">

        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Height" Value="60" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Padding" Value="10" />
            </Style>
        </TabControl.Resources>
        <TabItem Header="File Management">
            <v:FileManagerTab/>
        </TabItem>

        <TabItem Header="Chapters">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding ChapterViewModels}" DeleteItemCommand="{Binding DeleteChapterCommand}"/>
                    <Button Content="Add Chapter" Command="{Binding AddChapterCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Story Threads">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding StoryThreadViewModels}" DeleteItemCommand="{Binding DeleteStoryThreadCommand}"/>
                    <Button Content="Add StoryThread"  Command="{Binding AddStoryThreadCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Characters">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding CharacterViewModels}" DeleteItemCommand="{Binding DeleteCharacterCommand}"/>
                    <Button Content="Add Character"  Command="{Binding AddCharacterCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="CodexEntries">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding CodexEntryViewModels}" DeleteItemCommand="{Binding DeleteCodexEntryCommand}"/>
                    <Button Content="Add Codex Entry"  Command="{Binding AddCodexEntryCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Themes">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding ThemeViewModels}" DeleteItemCommand="{Binding DeleteThemeCommand}"/>
                    <Button Content="Add Theme"  Command="{Binding AddThemeCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Locations">
            <ScrollViewer>
                <StackPanel>
                    <v:CardCollectionViewer ItemsSource="{Binding LocationViewModels}" DeleteItemCommand="{Binding DeleteLocationCommand}"/>
                    <Button Content="Add Location"  Command="{Binding AddLocationCommand}" Style="{StaticResource AddButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="PlotPoints">
            <Button Content="Open Floating Plot Points" Command="{Binding OpenFloatingPointsCommand}" Width="160" Height="90"/>
        </TabItem>
        <TabItem Header="Gemini Prompts">
            <v:GeminiLibrary />
        </TabItem>

    </TabControl>
</Window>