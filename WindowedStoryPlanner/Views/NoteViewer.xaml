<UserControl x:Class="WindowedStoryPlanner.Views.NoteViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             mc:Ignorable="d" 
             d:DataContext="{x:Static local:Sample.NoteCollectionViewModel}">

    <UserControl.Resources>
        <DataTemplate x:Key="GhostNoteTemplate">
            <Border Background="#F0F0F0" 
                    BorderBrush="#666666" 
                    BorderThickness="2" 
                    CornerRadius="3" 
                    Padding="10"
                    Opacity="0.85" 
                    Width="250">
                <StackPanel>
                    <TextBlock Text="Moving Note..." FontWeight="Bold" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Content}" TextTrimming="CharacterEllipsis" MaxHeight="60"/>
                </StackPanel>

                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="5" Opacity="0.4"/>
                </Border.Effect>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="10,5" BorderBrush="#CCC" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="NOTES" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333"/>

                <Border x:Name="TrashZone"
                        Width="30" Height="30" 
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        dd:DragDrop.IsDropTarget="True"
                        dd:DragDrop.DropHandler="{Binding}">
                    <TextBlock Text="🗑️" FontSize="16" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               ToolTip="Drag note here to delete"/>
                </Border>

                <Button Content="+" Width="24" Height="24" HorizontalAlignment="Right" 
                        Command="{Binding AddNoteCommand}"/>
            </DockPanel>
        </Border>

        <ListBox ItemsSource="{Binding NoteCollection}" 
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0"
                 Background="Transparent"
                 dd:DragDrop.IsDragSource="True"
                 dd:DragDrop.IsDropTarget="True"
                 dd:DragDrop.DropHandler="{Binding}"
                 dd:DragDrop.DragAdornerTemplate="{StaticResource GhostNoteTemplate}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <local:NoteCard Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=local:NoteViewer}}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>