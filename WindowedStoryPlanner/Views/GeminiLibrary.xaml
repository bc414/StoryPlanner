<UserControl x:Class="WindowedStoryPlanner.Views.GeminiLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <ListBox ItemsSource="{Binding GeminiEntries}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" BorderBrush="Gray" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="🤖" FontSize="24" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="1" Text="{Binding Prompt}" 
                                       FontWeight="Normal" TextTrimming="CharacterEllipsis" 
                                       VerticalAlignment="Center" Margin="10,0"/>

                            <Button Grid.Column="2" 
                                    Content="{Binding Time, StringFormat='{}{0:MM/dd/yyyy}'}"
                                    ToolTip="{Binding Prompt}"
                                    Command="{Binding DataContext.OpenGeminiEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Padding="10,5" Margin="5">
                                
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#FF9999"/> 
                                        
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAnalyzed}" Value="True">
                                                <Setter Property="Background" Value="#90EE90"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
