<UserControl x:Class="WindowedStoryPlanner.Views.PlotPointListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop">
    <StackPanel>
        <ListBox ItemsSource="{Binding PlotPoints}"
                 SelectedItem="{Binding SelectedPlotPoint}"
                 dd:DragDrop.IsDragSource="True"
                 dd:DragDrop.IsDropTarget="False">
            <ListBox.InputBindings>
                <KeyBinding Key="Up" Modifiers="Alt" Command="{Binding MovePlotPointUpCommand}"/>
                <KeyBinding Key="Down" Modifiers="Alt" Command="{Binding MovePlotPointDownCommand}"/>
            </ListBox.InputBindings>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:PlotPointViewModel}">
                    <local:PlotPointCard/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="+ New Plot Point" Height="24" Command="{Binding AddPlotPointCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>