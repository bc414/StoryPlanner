<UserControl x:Class="WindowedStoryPlanner.Views.DefinitionsEditorControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=vm:DefinitionsEditorViewModel}">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style TargetType="Button" x:Key="AddButton">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style TargetType="Button" x:Key="DeleteButton">
            <Setter Property="Content" Value="✕"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="#CC0000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CC0000"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ToolTip" Value="Delete row"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- Subject Definitions section -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="100"/>
            <!-- Splitter -->
            <RowDefinition Height="6"/>
            <!-- Note Track Definitions section -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="150"/>
            <!-- Save bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Subject Definitions ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Subject Definitions" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
            <Button Content="+ Add" Style="{StaticResource AddButton}"
                    Command="{Binding AddSubjectDefinitionCommand}"
                    Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding SubjectDefinitions}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="40"/>

                <DataGridTemplateColumn Header="Subject Type" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SubjectType}" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SubjectType, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Reorder column -->
                <DataGridTemplateColumn Header="" Width="54" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▲" Width="24" Height="24"
                                        Padding="0" Margin="0,0,2,0"
                                        ToolTip="Move up"
                                        Command="{Binding DataContext.MoveSubjectDefinitionUpCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="▼" Width="24" Height="24"
                                        Padding="0"
                                        ToolTip="Move down"
                                        Command="{Binding DataContext.MoveSubjectDefinitionDownCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Delete button column -->
                <DataGridTemplateColumn Header="" Width="34" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DeleteButton}"
                                    Command="{Binding DataContext.DeleteSubjectDefinitionCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

        <!-- ── Note Track Definitions ── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,4">
            <TextBlock Text="Note Track Definitions" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
            <Button Content="+ Add" Style="{StaticResource AddButton}"
                    Command="{Binding AddNoteTrackDefinitionCommand}"
                    Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding NoteTrackDefinitions}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="36"/>

                <!-- Track Name -->
                <DataGridTemplateColumn Header="Track Name" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TrackName}" VerticalAlignment="Center" Margin="4,0" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding TrackName, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Display Question -->
                <DataGridTemplateColumn Header="Display Question" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayQuestion}" VerticalAlignment="Center"
                                       Margin="4,0" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding DisplayQuestion, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Explanation -->
                <DataGridTemplateColumn Header="Usage Directive" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding UsageDirective}" VerticalAlignment="Center"
                                       Margin="4,0" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding UsageDirective, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Audit Directive" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding AuditDirective}" VerticalAlignment="Center"
                       Margin="4,0" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding AuditDirective, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0" Padding="3" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Owner Type -->
                <DataGridTemplateColumn Header="Owner Type" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding OwnerType}" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding OwnerType, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.OwnerTypes,
                                                   RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Subject Type combo (resolves to SubjectDefinitionId on save) -->
                <DataGridTemplateColumn Header="Subject Type" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SelectedSubjectType}" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding SelectedSubjectType, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.AvailableSubjectTypes,
                                                   RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Cognitive Mode -->
                <DataGridTemplateColumn Header="Track Type" Width="115">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TrackType}" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding TrackType, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.TrackTypes,
                                                   RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Display Order columns — one per EditorMode -->
                <DataGridTemplateColumn Width="44" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Exp." ToolTip="Expansion mode display order"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ExpansionModeDisplayOrder}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ExpansionModeDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="44" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Link." ToolTip="Linking mode display order"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LinkingModeDisplayOrder}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding LinkingModeDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="44" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Gard." ToolTip="Gardener mode display order"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GardenerModeDisplayOrder}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding GardenerModeDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="44" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Audit" ToolTip="Audit mode display order"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding AuditModeDisplayOrder}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding AuditModeDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="44" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Scene" ToolTip="Scene Design mode display order"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SceneDesignModeDisplayOrder}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SceneDesignModeDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3" TextAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- IsSingleton -->
                <DataGridTemplateColumn Header="Singleton" Width="62" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSingleton, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSingleton, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- SupportsWorldDate -->
                <DataGridTemplateColumn Header="World Date" Width="70" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding SupportsWorldDate, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding SupportsWorldDate, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Theme" Width="70" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding SupportsTheme, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding SupportsTheme, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Edit in Audit" Width="70" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding CanEditInAuditMode, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding CanEditInAuditMode, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Delete -->
                <DataGridTemplateColumn Header="" Width="34" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DeleteButton}"
                                    Command="{Binding DataContext.DeleteNoteTrackDefinitionCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Save bar ── -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="+ Add" Style="{StaticResource AddButton}"
                    Command="{Binding AddNoteTrackDefinitionCommand}"
                    Margin="12,0,0,0" VerticalAlignment="Center"/>
            <Button Content="↕ Resort" Padding="14,5" Margin="0,0,8,0"
                    Command="{Binding ResortNoteTrackDefinitionsCommand}"
                    ToolTip="Re-sort tracks into their canonical order"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
            <Button Content="# Exp." Padding="10,5" Margin="0,0,4,0"
                    Command="{Binding AutoNumberExpansionModeDisplayOrdersCommand}"
                    ToolTip="Auto-number Expansion mode display orders by track type"/>
            <Button Content="# Link." Padding="10,5" Margin="0,0,4,0"
                    Command="{Binding AutoNumberLinkingModeDisplayOrdersCommand}"
                    ToolTip="Auto-number Linking mode display orders by track type"/>
            <Button Content="# Gard." Padding="10,5" Margin="0,0,4,0"
                    Command="{Binding AutoNumberGardenerModeDisplayOrdersCommand}"
                    ToolTip="Auto-number Gardener mode display orders by track type"/>
            <Button Content="# Audit" Padding="10,5" Margin="0,0,4,0"
                    Command="{Binding AutoNumberAuditModeDisplayOrdersCommand}"
                    ToolTip="Auto-number Audit mode display orders by track type"/>
            <Button Content="# Scene" Padding="10,5" Margin="0,0,8,0"
                    Command="{Binding AutoNumberSceneDesignModeDisplayOrdersCommand}"
                    ToolTip="Auto-number Scene Design mode display orders by track type"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
            <Button Content="Export for LLM" Padding="14,5" Margin="0,0,8,0"
                    Command="{Binding ExportDefinitionsToMarkdownCommand}"
                    ToolTip="Save definitions as Markdown for LLM ingestion"/>
            <Button Content="Save All" Padding="14,5"
                    Command="{Binding SaveAllCommand}"/>
        </StackPanel>

    </Grid>
</UserControl>