<UserControl x:Class="WindowedStoryPlanner.Views.SubjectPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="220">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="1"
            CornerRadius="3"
            Padding="8">
        <StackPanel Width="220">

            <!-- Combo pair -->
            <TextBlock Text="Type" FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Margin="0,0,0,2"/>
            <ComboBox x:Name="TypeCombo"
                      ItemsSource="{Binding SubjectDefinitions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      DisplayMemberPath="SubjectType"
                      SelectionChanged="TypeCombo_SelectionChanged"
                      Margin="0,0,0,4"/>

            <TextBlock Text="Subject" FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Margin="0,0,0,2"/>
            <ComboBox x:Name="SubjectCombo"
                      ItemsSource="{Binding FilteredSubjects, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      DisplayMemberPath="Name"
                      SelectionChanged="SubjectCombo_SelectionChanged"
                      Margin="0,0,0,8"/>

            <Separator Margin="0,0,0,8"/>

            <!-- Search box -->
            <TextBlock Text="Search" FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Margin="0,0,0,2"/>
            <TextBox x:Name="SearchBox"
                     Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,2"/>

            <!-- Search results: visible only when search text is non-empty -->
            <ListBox x:Name="SearchResultsList"
                     ItemsSource="{Binding SearchResults, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     DisplayMemberPath="Name"
                     MaxHeight="160"
                     Visibility="{Binding HasSearchText, RelativeSource={RelativeSource AncestorType=UserControl},
                                  Converter={StaticResource BoolToVis}}"
                     SelectionChanged="SearchResultsList_SelectionChanged"/>
        </StackPanel>
    </Border>
</UserControl>