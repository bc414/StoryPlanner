<UserControl x:Class="WindowedStoryPlanner.Views.ChapterLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChapterLibraryViewModel}">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="DeleteButton">
            <Setter Property="Content" Value="✕"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="#CC0000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CC0000"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ToolTip" Value="Delete chapter"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Chapters"
                       FontSize="14" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            
        </StackPanel>

        <!-- Table -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Chapters}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1">

            <DataGrid.Columns>

                <!-- Order index -->
                <DataGridTextColumn Header="#"
                                    Binding="{Binding OrderIndex}"
                                    IsReadOnly="True"
                                    Width="36"/>

                <!-- Title (inline edit) -->
                <DataGridTemplateColumn Header="Title" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="3"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Open button -->
                <DataGridTemplateColumn Header="" Width="80" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Open"
                                    Padding="6,2"
                                    Command="{Binding DataContext.OpenChapterCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Reorder -->
                <DataGridTemplateColumn Header="" Width="54" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▲" Width="24" Height="24"
                                        Padding="0" Margin="0,0,2,0"
                                        ToolTip="Move up"
                                        Command="{Binding DataContext.MoveChapterUpCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="▼" Width="24" Height="24"
                                        Padding="0"
                                        ToolTip="Move down"
                                        Command="{Binding DataContext.MoveChapterDownCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Delete -->
                <DataGridTemplateColumn Header="" Width="34" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DeleteButton}"
                                    Command="{Binding DataContext.DeleteChapterCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="+ Add Chapter"
        Padding="10,4"
        Command="{Binding AddChapterCommand}"/>
    </Grid>
</UserControl>
