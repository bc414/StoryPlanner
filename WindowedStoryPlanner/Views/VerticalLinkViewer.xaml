<UserControl x:Class="WindowedStoryPlanner.Views.VerticalLinkViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             x:Name="Root">
    <UserControl.Resources>
        <local:EntityToPayloadConverter x:Key="EntityToPayloadConverter"/>
    </UserControl.Resources>

    <ListView ItemsSource="{Binding ItemsSource, ElementName=Root}"
              HorizontalContentAlignment="Stretch"
              BorderThickness="0"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              dd:DragDrop.IsDropTarget="True"
              dd:DragDrop.DropHandler="{Binding DataContext, ElementName=Root}" 
              dd:DragDrop.IsDragSource="True">
        
        <ListView.ItemTemplate>
            <DataTemplate>
                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="CardCol"/>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ContentControl Content="{Binding}" Margin="0,0,10,0" VerticalAlignment="Top"/>

                        <ContentControl Grid.Column="1" VerticalAlignment="Top">
                            <ContentControl.Content>
                                <MultiBinding Converter="{StaticResource EntityToPayloadConverter}">
                                    <Binding /> <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext"/> </MultiBinding>
                            </ContentControl.Content>
                        </ContentControl>

                        <Button Grid.Column="2" Content="❌"
                                Command="{Binding DataContext.UnlinkEntityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" 
                                VerticalAlignment="Top" Margin="5,0,0,0"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</UserControl>