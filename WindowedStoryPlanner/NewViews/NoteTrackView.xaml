<UserControl x:Class="WindowedStoryPlanner.Views.NoteTrackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
             xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="260"
             d:DataContext="{d:DesignInstance Type=vm:NoteTrackViewModel}">

    <UserControl.Resources>
        <local:CognitiveModeToColorConverter x:Key="CognitiveModeToColor"/>
    </UserControl.Resources>

    <!-- Outer border color = CognitiveMode accent -->
    <Border BorderThickness="3"
            CornerRadius="6"
            Margin="4"
            BorderBrush="{Binding CognitiveMode, Converter={StaticResource CognitiveModeToColor}}">

        <DockPanel>

            <!-- ── Track header ── -->
            <Border DockPanel.Dock="Top"
                    CornerRadius="3,3,0,0"
                    Padding="8,6"
                    Background="{Binding CognitiveMode,
                                         Converter={StaticResource CognitiveModeToColor}}">

                <!-- Tooltip over the entire header shows Explanation -->
                <Border.ToolTip>
                    <ToolTip MaxWidth="320">
                        <TextBlock Text="{Binding Explanation}"
                                   TextWrapping="Wrap"/>
                    </ToolTip>
                </Border.ToolTip>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: TrackName + optional Fkey badge -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding TrackName}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                            <!-- F-key badge — hidden when FunctionKeyNumber is null -->
                            <Border CornerRadius="3"
                                    Background="#33FFFFFF"
                                    Padding="4,1"
                                    Margin="6,0,0,0"
                                    Visibility="{Binding FunctionKeyNumber,
                                                         Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Foreground="White"
                                           FontSize="10"
                                           FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="F{0}">
                                            <Binding Path="FunctionKeyNumber"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Display question as subtitle -->
                        <TextBlock Text="{Binding DisplayQuestion}"
                                   Foreground="#E0FFFFFF"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>

                    </StackPanel>

                    <!-- Right: + Add Note button -->
                    <Button Grid.Column="1"
                            Content="+"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="#33FFFFFF"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1"
                            Width="28" Height="28"
                            VerticalAlignment="Top"
                            ToolTip="Add new note to this track"
                            Command="{Binding CreateNewNoteCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#55FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#22FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </Grid>
            </Border>

            <!-- ── Three sections: Confirmed → Unset → Flagged ── -->
            <ItemsControl DockPanel.Dock="Bottom"
                          ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:NoteTrackSectionView/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </DockPanel>
    </Border>
</UserControl>
