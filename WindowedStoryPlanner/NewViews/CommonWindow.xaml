<Window x:Class="WindowedStoryPlanner.Views.CommonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        xmlns:vm="clr-namespace:WindowedStoryPlanner.ViewModels"
        mc:Ignorable="d"
        Title="Story Planner"
        Height="700" Width="1200"
        MinWidth="600" MinHeight="400" PreviewKeyDown="CommonWindow_PreviewKeyDown">

    <Window.Resources>
        <!-- Typed DataTemplates: ContentControl resolves these automatically by Content type -->
        <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
            <local:NarrativeElementFullView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlotPointViewModel}">
            <local:NarrativeElementFullView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlotPointSubjectLinkViewModel}">
            <local:NarrativeElementFullView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOP NAV BAR ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="NavigateLeftButton"
                    Grid.Column="0"
                    Content="◀  Subject"
                    IsEnabled="False"
                    Margin="4,4,2,4"
                    ToolTip="Navigate to subject (left-click) / Open in new window (middle-click)"
                    Click="NavigateLeft_Click"
                    PreviewMouseDown="NavigateLeft_PreviewMouseDown"/>

            <Button x:Name="NavigateRightButton"
                    Grid.Column="2"
                    Content="Plot Point  ▶"
                    IsEnabled="False"
                    Margin="2,4,4,4"
                    ToolTip="Navigate to plot point (left-click) / Open in new window (middle-click)"
                    Click="NavigateRight_Click"
                    PreviewMouseDown="NavigateRight_PreviewMouseDown"/>
        </Grid>

        <!-- ══ THREE-COLUMN CONTENT AREA ════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ─────────────────────────────────────────────── -->
            <ContentControl x:Name="LeftPanel"
                            Grid.Column="0"
                            Visibility="Collapsed"/>

            <!-- ── MIDDLE LINK CARD BAR ───────────────────────────────────── -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1,0">
                <ListBox x:Name="LinkCardsListBox"
                         BorderThickness="0"
                         SelectionChanged="LinkCards_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="4,4,4,0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PlotPointSubjectLinkViewModel}">
                            <Border Padding="6"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding PlotPointId}"/>
                                    <TextBlock FontSize="11"
                                               Foreground="Gray"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding SubjectId}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- ── RIGHT PANEL ────────────────────────────────────────────── -->
            <ContentControl x:Name="RightPanel"
                            Grid.Column="2"
                            Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
