<Window x:Class="WindowedStoryPlanner.Views.CommonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowedStoryPlanner.Views"
        mc:Ignorable="d"
        Title="CommonWindow" Height="700" Width="1100">

    <Window.Resources>
        <CollectionViewSource x:Key="SortedNoteTracks" Source="{Binding NoteTracks}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="DisplayOrder" Direction="Ascending"
                                     xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <!-- Outer ScrollViewer owns all vertical scrolling for the window -->
    <ScrollViewer x:Name="RootScroller"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  local:ScrollViewerHelper.BubbleMouseWheelToThis="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Main content area -->
                <ColumnDefinition Width="*"/>
                <!-- Right-side panel for connected entities -->
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT / MAIN COLUMN ══════════════════════════════════════ -->
            <DockPanel Grid.Column="0" LastChildFill="True">

                <!-- Top placeholder content control -->
                <ContentControl DockPanel.Dock="Top"
                                x:Name="TopContentPlaceholder"
                                MinHeight="80"
                                Margin="8,8,8,4"
                                Content="{Binding}"
                                Visibility="Collapsed"/>

                <!-- Note tracks — sorted, no internal vertical scroll -->
                <ItemsControl DockPanel.Dock="Top"
                              ItemsSource="{Binding Source={StaticResource SortedNoteTracks}}"
                              Margin="8,4,4,8"
                              VirtualizingPanel.IsVirtualizing="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:NoteTrackView Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <!-- ══ RIGHT COLUMN — connected entities placeholder ══════════ -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1,0,0,0"
                    Margin="4,8,8,8">
                <ContentControl x:Name="RightContentPlaceholder"
                                Content="{Binding}"
                                Visibility="Collapsed"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
